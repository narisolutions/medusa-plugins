{
  "name": "@narisolutions/medusa-plugin-pos",
  "version": "0.1.0",
  "description": "Medusa v2 plugin providing optimized POS endpoints",
  "author": "Nari Solutions",
  "license": "Apache-2.0",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    ".": {
      "require": "./.medusa/server/src/index.js",
      "default": "./.medusa/server/src/index.js"
    },
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/narisolutions/medusa-plugins.git",
    "directory": "plugins/medusa-plugin-pos"
  },
  "homepage": "https://github.com/narisolutions/medusa-plugins/tree/main/plugins/medusa-plugin-pos",
  "keywords": [
    "medusa-plugin",
    "medusa-v2",
    "pos",
    "point-of-sale",
    "nari-solutions"
  ],
  "scripts": {
    "build": "medusa plugin:build && node scripts/fix-aliases.js",
    "dev": "medusa plugin:develop",
    "dev:publish": "medusa plugin:publish",
    "prepublishOnly": "medusa plugin:build && node scripts/fix-aliases.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.15.0",
    "@medusajs/medusa": ">=2.15.0"
  },
  "devDependencies": {
    "@medusajs/cli": "^2.15.1",
    "@medusajs/framework": "^2.15.1",
    "@medusajs/medusa": "^2.15.1",
    "@medusajs/test-utils": "^2.15.1",
    "@medusajs/utils": "^2.15.1",
    "@swc/core": "^1.10.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
